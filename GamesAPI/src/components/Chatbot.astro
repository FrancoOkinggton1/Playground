---
// src/components/Chatbot.astro
---

<div class="fixed bottom-6 right-6 z-[100]">
  <button 
    id="chat-button"
    class="bg-blue-600 hover:bg-blue-700 text-white p-4 rounded-full shadow-2xl transition-all hover:scale-110 active:scale-95 group border-2 border-white/10"
  >
    <span class="text-2xl group-hover:rotate-12 inline-block">💬</span>
  </button>

  <div 
    id="chat-window" 
    class="hidden absolute bottom-20 right-0 w-80 md:w-96 bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl flex flex-col overflow-hidden transition-all backdrop-blur-md"
  >
    <div class="bg-slate-700 p-4 border-b border-slate-600 flex justify-between items-center bg-gradient-to-r from-slate-700 to-slate-800">
      <div class="flex items-center gap-2">
        <span class="text-xl animate-bounce">🤖</span>
        <span class="font-bold text-blue-400 tracking-wide">GAMEZONE AI</span>
      </div>
      <button id="close-chat" class="text-slate-400 hover:text-white transition-colors">✕</button>
    </div>

    <div id="chat-messages" class="h-80 overflow-y-auto p-4 space-y-4 text-sm">
      <div class="bg-slate-700 p-3 rounded-lg rounded-tl-none max-w-[85%] border border-slate-600">
        ¡Hola, Franco! Soy tu soporte técnico de **GameZone**. ¿Buscando algo épico para jugar hoy? 🎮
      </div>
    </div>

    <div class="p-4 bg-slate-800 border-t border-slate-700">
      <form id="chat-form" class="flex gap-2">
        <input 
          type="text" 
          id="chat-input"
          placeholder="Ej: Recomiéndame un RPG como The Witcher..." 
          class="flex-1 bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition-colors"
        />
        <button type="submit" class="bg-blue-600 px-4 py-2 rounded-lg font-bold hover:bg-blue-700 transition-all text-sm">
          Enviar
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const chatButton = document.getElementById('chat-button');
  const chatWindow = document.getElementById('chat-window');
  const closeChat = document.getElementById('close-chat');
  const chatForm = document.getElementById('chat-form') as HTMLFormElement | null;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;
  const chatMessages = document.getElementById('chat-messages') as HTMLElement | null;

  chatButton?.addEventListener('click', () => {
    chatWindow?.classList.toggle('hidden');
    chatInput?.focus();
  });

  closeChat?.addEventListener('click', () => {
    chatWindow?.classList.add('hidden');
  });

  chatForm?.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();
    if (!chatInput || !chatMessages) return;

    const message = chatInput.value.trim();
    if (!message) return;

    appendMessage('user', message);
    chatInput.value = '';

    const loadingId = 'loading-' + Date.now();
    appendLoadingIndicator(loadingId);

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message })
      });

      if (!response.ok) throw new Error('Error IA');
      const data = await response.json();

      removeLoadingIndicator(loadingId);
      appendMessage('bot', data.texto, data.link, data.nombre);

    } catch (error) {
      removeLoadingIndicator(loadingId);
      appendMessage('bot', "Error de conexión. Revisa tu internet o la API Key. 🛠️");
    }
  });

  function appendMessage(sender: 'user' | 'bot', text: string, link: string | null = null, gameName: string = "") {
    if (!chatMessages) return;
    const msgDiv = document.createElement('div');
    msgDiv.className = sender === 'user' 
      ? "bg-blue-600 p-3 rounded-lg rounded-tr-none max-w-[85%] ml-auto text-white shadow-md mb-4" 
      : "bg-slate-700 p-3 rounded-lg rounded-tl-none max-w-[85%] text-white shadow-md mb-4 border border-slate-600";
    
    let content = `<p>${text}</p>`;
    if (link) {
      content += `<a href="${link}" target="_blank" class="mt-3 block bg-blue-500 hover:bg-blue-400 text-center py-2 rounded-xl font-bold text-xs transition-all shadow-lg italic">🎮 Ver ${gameName} en Catálogo</a>`;
    }
    
    msgDiv.innerHTML = content;
    chatMessages.appendChild(msgDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function appendLoadingIndicator(id: string) {
    if (!chatMessages) return;
    const loadingDiv = document.createElement('div');
    loadingDiv.id = id;
    loadingDiv.className = "bg-slate-700 p-3 rounded-lg rounded-tl-none w-16 text-white mb-4 border border-slate-600 shadow-inner";
    loadingDiv.innerHTML = `<div class="flex gap-1 justify-center"><div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce"></div><div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce [animation-delay:-0.3s]"></div><div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce [animation-delay:-0.5s]"></div></div>`;
    chatMessages.appendChild(loadingDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function removeLoadingIndicator(id: string) {
    document.getElementById(id)?.remove();
  }
</script>