---
const currentYear = new Date().getFullYear();
---
<footer class="bg-slate-900 border-t border-slate-800 py-12 mt-20">
    <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-col items-start">
            
            <div class="mb-6">
                <a href="/" class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 hover:opacity-80 transition">
                    👾 GameZone
                </a>
                <p class="text-slate-400 mt-2 text-base max-w-xs">
                    Tu puerta al multiverso del gaming.
                </p>
            </div>
            
            <nav class="flex flex-wrap gap-8 mb-10 text-slate-300">
                <a href="#" class="hover:text-blue-400 transition-colors font-medium">GitHub</a>
                <a href="#" class="hover:text-blue-400 transition-colors font-medium">LinkedIn</a>
                <a href="#" class="hover:text-blue-400 transition-colors font-medium">Portafolio</a>
            </nav>

            <div class="pt-6 border-t border-slate-800 w-full md:w-auto">
                <p class="text-slate-500 text-sm">
                    &copy; {currentYear} Desarrollado Por <span class="text-slate-300 font-semibold text-base">Franco O"kinggton</span>.
                </p>
                <p class="text-slate-600 text-xs mt-1">
                    Software Developer | Villa Alemana, Chile.
                </p>
            </div>
        </div>
    </div>
</footer>