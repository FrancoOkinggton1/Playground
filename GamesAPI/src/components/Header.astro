---
// Lógica del Header (Las categorías)
const categories = [
    { name: 'Acción', slug: 'action' },
    { name: 'Indie', slug: 'indie' },
    { name: 'Aventura', slug: 'adventure' },
    { name: 'RPG', slug: 'role-playing-games-rpg' }
];
---

<header class="bg-slate-800 border-b border-slate-700 sticky top-0 z-50 shadow-md">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
        
        <a href="/" class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 hover:scale-105 transition">
            👾 GameZone
        </a>

        <nav class="flex gap-4">
            {categories.map(cat => (
                <a 
                    href={`/?genre=${cat.slug}`} 
                    class="text-sm font-medium text-slate-300 hover:text-blue-400 transition hover:border-b-2 border-blue-400 pb-1"
                >
                    {cat.name}
                </a>
            ))}
        </nav>
    </div>
</header>